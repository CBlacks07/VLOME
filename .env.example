# Copier en .env et renseigner les valeurs (ne jamais committer .env)

# ── Base de données ──
# Dev : voir apps/api/.env (SQLite). Prod : PostgreSQL.
DATABASE_URL="postgresql://user:password@localhost:5432/vlome?schema=public"

# ── Cache / temps réel ──
REDIS_URL="redis://localhost:6379"

# ── API ──
API_PORT=4000
JWT_SECRET="change-me-in-production"

# ── Frontend ──
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_WS_URL="http://localhost:4000"

# ── Paiements (agrégateur africain : CinetPay / PayDunya → Flooz, Mixx by Yas, cartes) ──
CINETPAY_API_KEY=""
CINETPAY_SITE_ID=""

# ── Stockage / CDN (Cloudflare R2) ──
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="vlome-media"

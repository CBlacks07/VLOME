// VLOME Esport — schéma PostgreSQL
// Sortie locale (pas dans node_modules) : évite les soucis de résolution du
// paquet @prisma/client hors monorepo pnpm hoisté (ex. build Vercel). Générée
// à la racine du package (pas sous src/) pour que le chemin relatif depuis
// prisma.service.ts reste valide identiquement en dev (ts-node, depuis src/)
// et en prod (node dist/main.js, depuis dist/), les deux arborescences ayant
// la même profondeur sous generated/.
generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PLAYER
  ORGANIZER
  ADMIN
}

enum TournamentFormat {
  SURVIVAL
  SINGLE_ELIM
  DOUBLE_ELIM
  SWISS
  ROUND_ROBIN
  POOLS
  BATTLE_ROYALE
}

enum TournamentStatus {
  DRAFT
  LIVE
  FINISHED
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  displayName   String
  role          Role           @default(PLAYER)
  bio           String?
  city          String?
  favoriteGame  String?
  createdAt     DateTime       @default(now())
  player        Player?
  registrations Registration[]
  orders        Order[]
}

// Inscription d'un utilisateur à un tournoi (avant lancement)
model Registration {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournamentId  String
  tournament    Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  playerName    String
  amountXof     Int        @default(0)
  paymentMethod String? // Flooz, Mixx by Yas, Visa... (null si gratuit)
  paymentStatus String     @default("paid") // 'paid' (gratuit ou confirmé) | 'pending' (paiement à confirmer)
  createdAt     DateTime   @default(now())

  @@unique([userId, tournamentId])
}

model Club {
  id      String   @id @default(cuid())
  name    String   @unique
  city    String?
  players Player[]
}

model Player {
  id        String   @id @default(cuid())
  name      String
  city      String?
  game      String?
  elo       Int      @default(1000)
  points    Int      @default(0)
  userId    String?  @unique
  user      User?    @relation(fields: [userId], references: [id])
  clubId    String?
  club      Club?    @relation(fields: [clubId], references: [id])
  createdAt DateTime @default(now())
}

model Tournament {
  id              String           @id @default(cuid())
  name            String
  game            String?
  format          TournamentFormat @default(SURVIVAL)
  status          TournamentStatus @default(DRAFT)
  date            DateTime?
  place           String?
  pointsPerPlayer Int              @default(5)
  nbPools         Int              @default(2)
  entryFeeXof     Int              @default(0) // frais d'inscription en FCFA (0 = gratuit)
  imageUrl        String?
  // état complet du moteur @vlome/engine (JSON natif Postgres)
  engineState     Json?
  createdById     String?          // propriétaire (organisateur)
  createdAt       DateTime         @default(now())
  matches         Match[]
  registrations   Registration[]
  galleryItems    GalleryItem[]
}

model Match {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  stage        String
  playerAId    String?
  playerBId    String?
  scoreA       Int        @default(0)
  scoreB       Int        @default(0)
  winnerId     String?
  playedAt     DateTime?
}

// Réglages éditables du site (identité, héro, slider, partenaires…)
model Setting {
  key   String @id
  value Json
}

// Galerie : photos/vidéos des événements (LAN, finales, remises de prix…)
model GalleryItem {
  id           String     @id @default(cuid())
  title        String
  mediaUrl     String // image ou vidéo (/uploads/...)
  mediaType    String     @default("image") // 'image' | 'video'
  tournamentId String?
  tournament   Tournament? @relation(fields: [tournamentId], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())
}

model NewsPost {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  category  String
  body      String
  imageUrl  String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Product {
  id        String   @id @default(cuid())
  name      String
  category  String
  priceXof  Int // prix en FCFA
  stock     Int      @default(0)
  imageUrl  String?
  createdAt DateTime @default(now())
}

model Order {
  id            String   @id @default(cuid())
  reference     String   @unique
  totalXof      Int
  paymentMethod String // Flooz, Mixx by Yas, Visa...
  status        String   @default("pending")
  items         Json? // [{ name, price }]
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  createdAt     DateTime @default(now())
}

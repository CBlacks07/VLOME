// VLOME Esport — schéma PostgreSQL
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PLAYER
  ORGANIZER
  ADMIN
}

enum TournamentFormat {
  SURVIVAL
  SINGLE_ELIM
  DOUBLE_ELIM
  SWISS
  ROUND_ROBIN
  POOLS
  BATTLE_ROYALE
}

enum TournamentStatus {
  DRAFT
  LIVE
  FINISHED
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  displayName   String
  role          Role           @default(PLAYER)
  bio           String?
  city          String?
  favoriteGame  String?
  createdAt     DateTime       @default(now())
  player        Player?
  registrations Registration[]
  orders        Order[]
}

// Inscription d'un utilisateur à un tournoi (avant lancement)
model Registration {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  playerName   String
  createdAt    DateTime   @default(now())

  @@unique([userId, tournamentId])
}

model Club {
  id      String   @id @default(cuid())
  name    String   @unique
  city    String?
  players Player[]
}

model Player {
  id        String   @id @default(cuid())
  name      String
  city      String?
  game      String?
  elo       Int      @default(1000)
  points    Int      @default(0)
  userId    String?  @unique
  user      User?    @relation(fields: [userId], references: [id])
  clubId    String?
  club      Club?    @relation(fields: [clubId], references: [id])
  createdAt DateTime @default(now())
}

model Tournament {
  id              String           @id @default(cuid())
  name            String
  game            String?
  format          TournamentFormat @default(SURVIVAL)
  status          TournamentStatus @default(DRAFT)
  date            DateTime?
  place           String?
  pointsPerPlayer Int              @default(5)
  nbPools         Int              @default(2)
  imageUrl        String?
  // état complet du moteur @vlome/engine (JSON natif Postgres)
  engineState     Json?
  createdById     String?          // propriétaire (organisateur)
  createdAt       DateTime         @default(now())
  matches         Match[]
  registrations   Registration[]
}

model Match {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  stage        String
  playerAId    String?
  playerBId    String?
  scoreA       Int        @default(0)
  scoreB       Int        @default(0)
  winnerId     String?
  playedAt     DateTime?
}

model NewsPost {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  category  String
  body      String
  imageUrl  String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Product {
  id        String   @id @default(cuid())
  name      String
  category  String
  priceXof  Int // prix en FCFA
  stock     Int      @default(0)
  imageUrl  String?
  createdAt DateTime @default(now())
}

model Order {
  id            String   @id @default(cuid())
  reference     String   @unique
  totalXof      Int
  paymentMethod String // Flooz, Mixx by Yas, Visa...
  status        String   @default("pending")
  items         Json? // [{ name, price }]
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  createdAt     DateTime @default(now())
}

# Dev = PostgreSQL local (base "vlome"). Copier en .env (non committé).
DATABASE_URL="postgresql://postgres:MOT_DE_PASSE@localhost:5432/vlome?schema=public"

# Secret JWT pour l'authentification (à changer en production)
JWT_SECRET="change-me-in-production"

# Port d'écoute de l'API (défaut : 4000)
API_PORT=4000
